# =============================================================================
# CodeDrip — environment template
# Copy to `.env` and fill in real values:   cp .env.example .env
#
# WHITE-LABEL RULE: rebranding the store needs only env vars + the single
# store_settings DB row — never code changes. Anything the BROWSER may read is
# prefixed NEXT_PUBLIC_. Everything else is server-only and must never ship to
# the client (see HARD INVARIANT #1).
# =============================================================================

# ---------------------------------------------------------------------------
# Frontend (apps/web) — ONLY NEXT_PUBLIC_* vars are exposed to the browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=CodeDrip
NEXT_PUBLIC_YOUTUBE_DEMO_ID=dQw4w9WgXcQ

# Google Search Console verification code for SEO.
GOOGLE_SEARCH_CONSOLE_VERIFICATION=

# ---------------------------------------------------------------------------
# Backend (apps/api) — server-only. Never prefix these with NEXT_PUBLIC_.
# ---------------------------------------------------------------------------
PORT=4000

# Postgres connection. The schema/seed live in db/*.sql.
# Production: use a managed PostgreSQL provider (Railway, Supabase, Neon).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codedrip

# JWT signing secrets. Generate strong, DISTINCT values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Both secrets must be at least 32 characters and MUST differ from each other.
JWT_SECRET=replace-with-a-64+-char-random-string-do-not-use-this-value-aaaaaaaa
JWT_REFRESH_SECRET=replace-with-a-DIFFERENT-64+-char-random-string-bbbbbbbbbbbbbbbb

# Token lifetimes. Access tokens are short (15min); refresh tokens are long (7d)
# and rotated on every refresh call.
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# bcrypt work factor. 12 is the project standard — never set below 12 in production.
# Each increment of 1 doubles the hash time (~100ms at 10, ~400ms at 12, ~1600ms at 14).
BCRYPT_ROUNDS=12

# CORS allow-list for the API. Comma-separate multiple origins. Must include the
# frontend origin (NEXT_PUBLIC_SITE_URL). In development the API also accepts any
# localhost port automatically, so a fallback to :3001 still works.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Local file uploads (dev). Swap to S3 in prod — see README "File uploads".
UPLOAD_DIR=./uploads
# Maximum file size in bytes. Default 5MB (5 * 1024 * 1024).
MAX_FILE_SIZE=5242880

NODE_ENV=development

# ---------------------------------------------------------------------------
# SMTP for transactional email. Leave blank to use the console "mock" transport
# (emails are logged to the API console instead of sent).
# Production: use SendGrid, Resend, or Brevo (formerly Sendinblue).
# ---------------------------------------------------------------------------
SITE_URL=http://localhost:3000
NOTIFICATION_EMAIL=admin@codedrip.dev
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@codedrip.dev

# ---------------------------------------------------------------------------
# Database connection pool sizing.
# Rule of thumb: (2 × CPU cores) + active disk spindles. Start with 20.
# ---------------------------------------------------------------------------
DB_POOL_MAX=20    # Max connections in the pool
DB_POOL_MIN=2     # Minimum connections kept alive

# ---------------------------------------------------------------------------
# Log verbosity: error | warn | info | debug.
# Use 'debug' for local development, 'info' for production.
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Redis — optional but strongly recommended for production.
# Enables distributed rate limiting (limits survive server restarts and work
# across multiple API instances).
# Get a free instance at upstash.com or use Railway's Redis plugin.
# ---------------------------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------------------------
# Sentry DSN — optional but strongly recommended for production error tracking.
# Catches crashes, tracks errors, and alerts you when things break.
# Get a free tier account at sentry.io.
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Cron job authentication secret.
# Used to authenticate Vercel Cron job requests (e.g., expired token cleanup).
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------------------
CRON_SECRET=
