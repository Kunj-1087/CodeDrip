{
  "name": "ourscart",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace=apps/web run dev",
    "dev:api": "npm --workspace=apps/api run dev",
    "build": "npm --workspace=apps/web run build && npm --workspace=apps/api run build",
    "start:api": "npm --workspace=apps/api run start",
    "start:web": "npm --workspace=apps/web run start",
    "db:migrate": "node scripts/migrate.mjs",
    "db:seed": "node scripts/migrate.mjs --seed",
    "db:reset": "node scripts/migrate.mjs --reset --seed",
    "typecheck": "npm --workspace=apps/api run typecheck"
  },
  "devDependencies": {
    "pg": "^8.12.0"
  }
}
