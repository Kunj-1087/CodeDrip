# ===========================
# OursCart Mobile App — Environment Variables
# ===========================
# Copy this file to .env and fill in the values
# All EXPO_PUBLIC_* vars are bundled into the app binary — never put secrets here

# API connection
EXPO_PUBLIC_API_URL=http://localhost:4000
# In production: https://your-api-domain.com
# Must start with https:// in production — app will throw if it starts with http://
# Default: http://localhost:4000

# App metadata
EXPO_PUBLIC_STORE_NAME=OursCart
EXPO_PUBLIC_APP_VERSION=1.0.0
# Used in request headers so the API can log which app version is calling it

# Environment flag
EXPO_PUBLIC_ENV=development
# Set to 'production' for Play Store builds. Controls: Sentry, console logs, update checks.

# Error monitoring (strongly recommended before Play Store submission)
EXPO_PUBLIC_SENTRY_DSN=
# From sentry.io → New Project → React Native → copy DSN
# Free tier: 5,000 errors/month. Enough for launch.
# Leave empty to disable Sentry (not recommended in production)

# OTA Updates (optional — requires EAS)
EXPO_PUBLIC_ENABLE_OTA_UPDATES=false
# Set to 'true' only when using EAS Update for OTA deployments

# Demo video (optional)
EXPO_PUBLIC_DEMO_VIDEO_YOUTUBE_ID=
# YouTube video ID (11 characters). Leave empty to show placeholder card.
