{
  "expo": {
    "name": "OursCart",
    "slug": "ourscart",
    "version": "1.0.0",
    "description": "Shop FocusKit — student planners, Notion templates, printables and desk accessories for productivity.",
    "keywords": ["FocusKit", "student", "productivity", "planners", "Notion templates", "desk accessories"],
    "primaryColor": "#D97757",
    "orientation": "portrait",
    "scheme": "ourscart",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "githubUrl": "",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#D97757"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.ourscart.app",
      "supportsTablet": false,
      "associatedDomains": ["applinks:ourscart.in", "applinks:ourscart-vercel.app"]
    },
    "android": {
      "package": "com.ourscart.app",
      "adaptiveIcon": {
        "backgroundColor": "#D97757"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "ourscart-vercel.app",
              "pathPrefix": "/shop"
            },
            {
              "scheme": "https",
              "host": "ourscart-vercel.app",
              "pathPrefix": "/orders"
            },
            {
              "scheme": "https",
              "host": "ourscart-vercel.app",
              "pathPrefix": "/cart"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}
