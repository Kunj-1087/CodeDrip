# =============================================================================
# CodeDrip API — Production Environment Variables for Railway
# =============================================================================
# Set these in the Railway dashboard under Service → Variables.
# NEVER commit real values to git.

# --- Server ---
NODE_ENV=production
PORT=4000

# --- Database ---
# Railway provides DATABASE_URL automatically when you add a PostgreSQL service.
# If using an external provider (Neon, Supabase), paste the connection string here.
DATABASE_URL=postgresql://user:pass@host:5432/codedrip?sslmode=require

# --- Auth (generate strong, distinct values) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_64_CHAR_RANDOM_STRING
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
BCRYPT_ROUNDS=12

# --- CORS ---
# Must match your Vercel frontend URL exactly.
CORS_ORIGIN=https://your-app.vercel.app

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# --- SMTP (optional — logs to console if blank) ---
SITE_URL=https://your-app.vercel.app
NOTIFICATION_EMAIL=admin@codedrip.dev
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@codedrip.dev

# --- Connection Pool ---
DB_POOL_MAX=20
DB_POOL_MIN=2

# --- Logging ---
LOG_LEVEL=info

# --- Optional Services ---
REDIS_URL=
SENTRY_DSN=
CRON_SECRET=
